# Server settings
HOST=127.0.0.1
PORT=8765

# Database selection (optional)
# Default is local SQLite at ./crm.sqlite3
# To use PostgreSQL/Supabase, set one of these URLs:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require
# SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# Requires Python package: psycopg[binary]

# Supabase client settings (required for supabase-js apps)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-public-anon-key
# Server-side only. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Local demo login fallback (used only when Supabase Auth is not configured)
DEMO_LOGIN_PASSWORD=demo123

# OpenAI API (required for AI assistant, email drafts, WhatsApp auto-reply)
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=25
AI_SESSION_LIMIT=40
AI_SESSION_WINDOW_SECONDS=3600

# Gmail SMTP settings (required for real email sending)
# For Gmail: use an App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# Meta WhatsApp Cloud API (required for real WhatsApp sending)
# Get token from: https://developers.facebook.com/apps/
# Phone Number ID from your WhatsApp Business Account
META_WHATSAPP_TOKEN=your-meta-whatsapp-token
META_PHONE_NUMBER_ID=your-phone-number-id

# Twilio WhatsApp (optional; used before Meta fallback when configured)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=+14155238886

# Follow-up scheduler (default every hour)
FOLLOWUP_POLL_SECONDS=3600
